    "contents" : "\n##############################################\n#\n#### Power Producer Summary ####\n#\n##############################################\n\n\n## Importing Hubspot data into R for Quarterly Report\nlibrary(dplyr)\nlibrary(stringi)\nlibrary(xtable)\n\n## Preprocess files\n#read in power_producers data file\npower_producers <- read.csv(file=\"power_producer.csv\", header=TRUE, sep=\",\")\npower_producers.prior <- read.csv(file=\"power_producer-old.csv\", header=TRUE, sep=\",\")\npower_producers_web <- read.csv(file=\"power_producer_attendees.csv\", header=TRUE, sep=\",\")\n\n\n##clean prior period files\n#pull only fields we need for prior numbers\npower_producers.prior <- select(power_producers.prior,\n                          Email,\n                          Emails.Delivered,\n                          Emails.Opened,\n                          Emails.Clicked,\n                          Number.of.Pageviews,\n                          Number.of.Visits\n)\n\npower_producers_web <- select(power_producers_web,\n                              Email,\n                              Website,\n                              Twitter,\n                              Facebook,\n                              LinkedIn\n)\n\n#renames fields to prep for merge\npower_producers.prior <- rename(power_producers.prior, Emails.Delivered.Prior = Emails.Delivered)\npower_producers.prior <- rename(power_producers.prior, Emails.Opened.Prior = Emails.Opened)\npower_producers.prior <- rename(power_producers.prior, Emails.Clicked.Prior = Emails.Clicked)\npower_producers.prior <- rename(power_producers.prior, Number.of.Pageviews.Prior = Number.of.Pageviews)\npower_producers.prior <- rename(power_producers.prior, Number.of.Visits.Prior = Number.of.Visits)\n\n\n#merges prior fields with most recent data\npower_producers <- merge(power_producers,power_producers.prior)\npower_producers <- merge (power_producers,power_producers_web)\n\n##cleans current file\n\n#date conversion from csv in date only format\npower_producers$Last.email.open.date<-as.Date(power_producers$Last.email.open.date, \"%m/%d/%y\")\npower_producers$Last.email.click.date<-as.Date(power_producers$Last.email.click.date, \"%m/%d/%y\")\npower_producers$Time.of.Last.Session<-as.Date(power_producers$Time.of.Last.Session, \"%m/%d/%y\")\n\n#add open rate calculation\npower_producers$Open.Rate <-power_producers$Emails.Opened / power_producers$Emails.Delivered\npower_producers$Open.Rate <- ifelse(is.na(power_producers$Open.Rate),\n                              0, power_producers$Open.Rate )\n\n#adds true or false based on recency of activity\npower_producers$Opened.In.Last.Week <- ifelse(power_producers$Last.email.open.date > Sys.Date() - 30, \"TRUE\", \"FALSE\")\npower_producers$Visited.In.Last.Week <- ifelse(power_producers$Time.of.Last.Session > Sys.Date() - 30, \"TRUE\", \"FALSE\")\n\n#clears nulls from key fields\n\n#cleans column names\npower_producers <- rename(power_producers, SF.Top.Level.Account = Top.Level.Account)\npower_producers <- rename(power_producers, Top.Level.Account = Top.Level.Account..Text.)\npower_producers <- rename(power_producers, SF.Account.Name = Name)\n\n#title case conversion\n\npower_producers$Top.Level.Account <- stri_trans_totitle(power_producers$Top.Level.Account)\npower_producers$First.Name <- stri_trans_totitle(power_producers$First.Name)\npower_producers$Last.Name <- stri_trans_totitle(power_producers$Last.Name)\npower_producers$Company.Name <- stri_trans_totitle(power_producers$Company.Name)\npower_producers$MGA.Name <- stri_trans_totitle(power_producers$MGA.Name)\npower_producers$SF.Account.Name <- stri_trans_totitle(power_producers$SF.Account.Name)\n\n#creates summary table by firm\n#distinct(select(power_producers, Top.Level.Account))\nIMO_summary <- group_by(power_producers, Top.Level.Account)\nIMO_summary <- summarise(IMO_summary, power_producers = n(), \n                         Opt_outs = sum(Opted.out.of.all.email == 'true', na.rm=TRUE),\n                         mean_open = mean(Open.Rate),\n                         opened_mail = sum(Opened.In.Last.Week == 'TRUE', na.rm=TRUE),\n                         visited_web = sum(Visited.In.Last.Week == 'TRUE', na.rm=TRUE))\n\n#add open rate/visitation pct calculation\nIMO_summary$opened_mail_pct <- round(IMO_summary$opened_mail/IMO_summary$power_producers, 2)\nIMO_summary$visited_web_pct <- round(IMO_summary$visited_web/IMO_summary$power_producers, 2)\n\nIMO_summary$mean_open <- round(IMO_summary$mean_open,2)\n\n\n####Opt outs\nIMO_drilldown_detail.optouts <- subset(power_producers, power_producers$Opted.out.of.all.email==\"true\")\n\nIMO_drilldown_detail.optouts <- select(IMO_drilldown_detail.optouts,\n                                       Email, First.Name, Last.Name)\n\n##Email Opens\nIMO_summary_detail <- power_producers\nIMO_summary_detail$First.Name <-strtrim(IMO_summary_detail$First.Name,12)\nIMO_summary_detail$Last.Name <-strtrim(IMO_summary_detail$Last.Name,12)\nIMO_summary_detail.opens <- select(IMO_summary_detail,\n                                   First.Name, Last.Name, Top.Level.Account, Open.Rate)\nIMO_summary_detail.opens <- IMO_summary_detail.opens[order(-IMO_summary_detail.opens$Open.Rate, IMO_summary_detail.opens$Last.Name),]\nIMO_summary_detail.opens$Open.Rate <- round(IMO_summary_detail.opens$Open.Rate, digits = 2)\n\n\n###Social Presence\n\n# web\n\npower_producers$Twitter <- as.character(power_producers$Twitter)\npower_producers$LinkedIn <- as.character(power_producers$LinkedIn)\npower_producers$Website <- as.character(power_producers$Website)\npower_producers_social <- select (power_producers,\n                                  Last.Name,\n                                  First.Name,\n                                  Twitter,\n                                  Facebook,\n                                  LinkedIn,\n                                  Website)\npower_producers_social <- power_producers_social[order(power_producers_social$Last.Name),]\nsocial1 <- select (power_producers_social,\n                   Last.Name,\n                   First.Name,\n                   Twitter,\n                   Facebook,\n                   LinkedIn,\n                   Website)\n\n\n\n\n## stop here\n\n# emails that aren't matched\nmatched_email <- select(power_producers, Email)\nmatched_email$Matched <- \"Yes\"\nmissing_email <- left_join(power_producers_web, matched_email, by = \"Email\")\nmissing_email$Matched <- ifelse(is.na(missing_email$Matched),\n                                    \"No\", missing_email$Matched)\nmissing_email2 <- subset (missing_email, missing_email$Matched == \"No\")\nwrite.csv(missing_email2, file = \"missing_emails.csv\")\n",
